{
  "info": {
    "name": "Investment Portfolio Management API",
    "description": "API Collection for Investment Portfolio Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Portfolios",
      "item": [
        {
          "name": "Create Portfolio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Investment Portfolio\",\n  \"description\": \"Personal investment portfolio\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/portfolios",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios"]
            }
          }
        },
        {
          "name": "Get All Portfolios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portfolios?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Portfolio Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portfolios/analytics",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "analytics"]
            }
          }
        },
        {
          "name": "Get Portfolio by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}"]
            }
          }
        },
        {
          "name": "Update Portfolio",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Portfolio Name\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}"]
            }
          }
        },
        {
          "name": "Delete Portfolio",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Assets",
      "item": [
        {
          "name": "Add Asset to Portfolio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"AAPL\",\n  \"quantity\": 10,\n  \"buyPrice\": 150.00,\n  \"currentPrice\": 160.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}/assets",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}", "assets"]
            }
          }
        },
        {
          "name": "Update Asset",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPrice\": 165.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}/assets/{{asset_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}", "assets", "{{asset_id}}"]
            }
          }
        },
        {
          "name": "Remove Asset from Portfolio",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/portfolios/{{portfolio_id}}/assets/{{asset_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "portfolios", "{{portfolio_id}}", "assets", "{{asset_id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "portfolio_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "asset_id",
      "value": "",
      "type": "string"
    }
  ]
}
