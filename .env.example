# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/investment-portfolio
# Backward-compatible alias supported by this project:
# MONGO_URI=mongodb://localhost:27017/investment-portfolio
# For MongoDB Atlas (cloud):
# MONGODB_URI=your_mongodb_atlas_connection_string
# Get this value from MongoDB Atlas → Database → Connect → Drivers.

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=*
# For production, use specific origins:
# CORS_ORIGIN=https://yourfrontend.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
